{
  "name": "pmusic",
  "private": true,
  "version": "1.5.0",
  "description": "PMusic — Apple Music style desktop client for YouTube Music",
  "author": "PMusic",
  "repository": {
    "type": "git",
    "url": "https://github.com/pufffissal/PMusic.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--disable-warning=DEP0040 vite",
    "dev:web": "npm run dev --prefix webplayer",
    "android": "npm run android --prefix android-app",
    "build": "npm run build:app && electron-builder --win msi",
    "build:app": "tsc -b && vite build",
    "dist": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "publish:win": "powershell -ExecutionPolicy Bypass -File scripts/publish-release.ps1",
    "verify:release": "powershell -ExecutionPolicy Bypass -File scripts/verify-release.ps1",
    "dist:msi": "npm run build:app && electron-builder --win msi",
    "dist:dir": "npm run build:app && electron-builder --win dir",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "electron-builder --dir",
    "postinstall": "electron-rebuild -f -w better-sqlite3 -w discord-rpc"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-virtual": "^3.13.12",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "discord-rpc": "^4.0.1",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "node-vibrant": "^4.0.0",
    "play-dl": "^1.9.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.4.0",
    "ytmusic-api": "^5.3.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
